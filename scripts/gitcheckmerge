#!/bin/zsh


#Text coloring functions
function color {
    if tty -s
    then
        tput setaf $2
        echo "$1"
        tput sgr0
        return
    fi

    echo "$1"
}

function red {
    color "$1" 1
}

function yellow {
    color "$1" 3
}

function green {
    color "$1" 2
}


MAIN_BRANCH="main"
TEMP_BRANCH="__gitcheckmerge_tmp__"
WORKTREE_DIR=""

function cleanup {
    if [[ -n "$WORKTREE_DIR" && -d "$WORKTREE_DIR" ]]; then
        git worktree remove --force "$WORKTREE_DIR" 2>/dev/null
        rm -rf "$WORKTREE_DIR" 2>/dev/null
    fi
    git branch -D "$TEMP_BRANCH" --quiet 2>/dev/null
}

trap cleanup EXIT


#Parse arguments
branches=()

while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            echo "Usage: gitcheckmerge <branch1> <branch2> [...]"
            echo ""
            echo "Checks whether the given branches can be merged into $MAIN_BRANCH"
            echo "in the provided order without conflicts. Nondestructive — does not"
            echo "modify any existing branches."
            echo ""
            echo "Options:"
            echo "  -h, --help    Show this help message"
            exit 0
            ;;
        -*)
            red "Unknown option: $1"
            exit 1
            ;;
        *)
            branches+=("$1")
            shift
            ;;
    esac
done

if [[ ${#branches[@]} -eq 0 ]]; then
    red "Error: at least one branch is required"
    echo "Usage: gitcheckmerge <branch1> <branch2> [...]"
    exit 1
fi

# Validate all branches exist before starting
for branch in "${branches[@]}"; do
    if ! git rev-parse --verify "refs/heads/$branch" &>/dev/null && \
       ! git rev-parse --verify "refs/remotes/origin/$branch" &>/dev/null; then
        red "Error: branch '$branch' does not exist"
        exit 1
    fi
done

# Validate main exists
if ! git rev-parse --verify "$MAIN_BRANCH" &>/dev/null; then
    red "Error: branch '$MAIN_BRANCH' does not exist"
    exit 1
fi

green "Setting up temporary worktree from $MAIN_BRANCH..."
WORKTREE_DIR=$(mktemp -d)
git branch --no-track "$TEMP_BRANCH" "$MAIN_BRANCH"
git worktree add "$WORKTREE_DIR" "$TEMP_BRANCH" --quiet

echo ""

results=()
all_clean=true

for branch in "${branches[@]}"; do
    yellow "Checking: $branch"

    merge_output=$(git -C "$WORKTREE_DIR" merge --no-ff --no-commit "$branch" 2>&1)
    merge_status=$?

    if [[ $merge_status -eq 0 ]]; then
        # Check for actual conflicts (--no-commit succeeds even with conflicts sometimes)
        conflict_files=$(git -C "$WORKTREE_DIR" diff --name-only --diff-filter=U 2>/dev/null)
        if [[ -n "$conflict_files" ]]; then
            merge_status=1
        fi
    fi

    if [[ $merge_status -eq 0 ]]; then
        git -C "$WORKTREE_DIR" commit --no-edit -m "Simulated merge of $branch" --quiet --allow-empty >/dev/null 2>&1
        green "  OK: $branch merges cleanly"
        results+=("ok:$branch")
    else
        git -C "$WORKTREE_DIR" merge --abort 2>/dev/null
        red "  CONFLICT: $branch would have merge conflicts"
        results+=("conflict:$branch")
        all_clean=false
    fi
done

echo ""
yellow "Summary (merging into $MAIN_BRANCH in order):"
for result in "${results[@]}"; do
    result_status="${result%%:*}"
    branch="${result#*:}"
    if [[ "$result_status" == "ok" ]]; then
        green "  ✓ $branch"
    else
        red "  ✗ $branch"
    fi
done

echo ""
if $all_clean; then
    green "All branches merge cleanly in this order."
else
    red "One or more branches would conflict. Conflicting branches are skipped when checking subsequent merges."
fi
