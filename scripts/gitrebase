#!/bin/zsh


#Text coloring functions
function color {
    if tty -s
    then
        tput setaf $2
        echo "$1"
        tput sgr0
        return
    fi
    
    echo "$1"
}

function red {
    color "$1" 1
}

function yellow {
    color "$1" 3
}

function green {
    color "$1" 2
}

#Safe say function that checks if command exists
function safe_say {
    if command -v say &> /dev/null; then
        say "$1"
    fi
}


#Prompt to continue
function confirm {
    yellow "Press y to continue, any other key to exit"
	tput bel

    read -q "variable?"
    echo ""
    if [[ $variable != "y" && $variable != "Y" ]]
    then
        red "Exiting"
        safe_say "Done"
        exit 0
    fi
    green "Continuing"
}

#Parse arguments
NO_PUSH=false
RESOLVE_TIMID=false
RESOLVE_BOLD=false

while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            echo "Usage: gitrebase [options]"
            echo ""
            echo "Rebases the current branch onto its parent branch."
            echo ""
            echo "Options:"
            echo "  -n, --no-push        Skip the force-push after rebasing"
            echo "  --resolve-timid      Resolve conflicts in favor of the branch being rebased onto"
            echo "  --resolve-bold       Resolve conflicts in favor of the branch being rebased"
            echo "  -h, --help           Show this help message"
            exit 0
            ;;
        -n|--no-push)
            NO_PUSH=true
            shift
            ;;

        # Resolve in favor of the branch being rebased onto. This is typically another developer's changes. This will use the "ours" strategy.
        --timid)
            RESOLVE_TIMID=true
            shift
            ;;

        # Resolve in favor of the branch being rebased. This is typically the developer's changes. This will use the "theirs" strategy.
        --bold)
            RESOLVE_BOLD=true
            shift
            ;;            
        *)
            red "Unknown option: $1"
            exit 1
            ;;
    esac
done

green "Getting current branch..."
currentBranch=$(git rev-parse --abbrev-ref HEAD)

green "Current branch is $currentBranch, determining ancestor..."
branchedFrom=$(gitparent);

REBASE_ARGS=""
if [ "$RESOLVE_TIMID" = true ]; then
    REBASE_ARGS="-X ours"
fi
if [ "$RESOLVE_BOLD" = true ]; then
    REBASE_ARGS="-X theirs"
fi


green "Rebasing $currentBranch onto $branchedFrom..."
COMMAND="git pull --rebase origin $branchedFrom $REBASE_ARGS"
yellow "Running: $COMMAND"

eval "$COMMAND"

if ! [ $? -eq 0 ] ; then
	red "Rebase failed! Make appropriate code changes and then use:"
	red "git rebase --continue"
	red "Or to abort, use:"
	red "git rebase --abort"
	exit 1
fi

if [ "$NO_PUSH" = true ]; then
	green "Rebase complete. Skipping push (--no-push flag set)"
	green "Done"
	exit 0
fi

green "Force-push $currentBranch to origin?"
confirm
git push --force-with-lease origin

green "Done"