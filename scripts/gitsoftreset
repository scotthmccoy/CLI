#!/bin/zsh
#Text coloring functions
function color {
    if tty -s
    then
        tput setaf $2
        echo "$1"
        tput sgr0
        return
    fi
    
    echo "$1"
}

function red {
    color "$1" 1
}

function yellow {
    color "$1" 3
}

function green {
    color "$1" 2
}

#Safe say function that checks if command exists
function safe_say {
    if command -v say &> /dev/null; then
        say "$1"
    fi
}


#Prompt to continue
function confirm {
    yellow "Press y to continue, any other key to exit"
	tput bel

    read -q "variable?"
    echo ""
    if [[ $variable != "y" && $variable != "Y" ]]
    then
        red "Exiting"
        safe_say "Done"
        exit 0
    fi
    green "Continuing"
}


#Parse arguments
PULL_PARENT=true
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            echo "Usage: gitsoftreset [options]"
            echo ""
            echo "Soft-resets the current branch to the merge-base with its parent branch."
            echo "All commits since the merge-base become staged changes."
            echo ""
            echo "By default, pulls the parent branch first to ensure the merge-base is up to date."
            echo ""
            echo "Options:"
            echo "  --no-update    Skip pulling the parent branch before resetting"
            echo "  -h, --help     Show this help message"
            exit 0
            ;;
        --no-pull-parent)
            PULL_PARENT=false
            shift
            ;;
        *)
            red "Unknown option: $1"
            exit 1
            ;;
    esac
done


green "Getting current branch..."
workingBranch=$(git rev-parse --abbrev-ref HEAD)

if [[ $PULL_PARENT == true ]]; then
    green "Current branch is $workingBranch, determining ancestor..."
    parent=$(gitparent) || { red "gitparent failed: $parent"; exit 1; }

    green "Switching to parent branch $parent..."
    git checkout $parent
    sleep 1

    green "Pulling..."
    git pull

    green "Switching back to $workingBranch..."
    git checkout $workingBranch
fi

firstCommitHash=$(gitfirstcommithash) || { red "gitfirstcommithash failed: $firstCommitHash"; exit 1; }
firstCommitMessage=$(git log -1 --format=%B $firstCommitHash)

mergeBaseCommitHash=$(gitmergebase) || { red "gitmergebase failed: $mergeBaseCommitHash"; exit 1; }
mergeBaseCommitMessage=$(git log -1 --format=%B $mergeBaseCommitHash)

green "First commit on branch $workingBranch $firstCommitHash is: \n$firstCommitHash"

green "Merge base commit $mergeBaseCommitHash is: \n$mergeBaseCommitMessage"

green "Soft-reset to merge base of $mergeBaseCommitHash?"

confirm 

git reset --soft $hashOfMergeBase